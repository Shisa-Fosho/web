{
  "name": "shisa-web",
  "private": true,
  "scripts": {
    "dev": "turbo dev",
    "dev:main": "turbo dev --filter=@shisa/main",
    "dev:admin": "turbo dev --filter=@shisa/admin",
    "build": "turbo build",
    "lint": "turbo lint",
    "type-check": "turbo type-check",
    "test": "turbo test",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
  },
  "devDependencies": {
    "prettier": "^3.3.3",
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.15.4"
}
